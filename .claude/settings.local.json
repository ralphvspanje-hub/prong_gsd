{
  "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": true,
  "permissions": {
    "allow": [
      "Bash(cmd /c \"conda env list\")"
    ]
  },
  "enabledMcpjsonServers": [
    "linear"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-after-edit.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck-after-edit.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact-save.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
